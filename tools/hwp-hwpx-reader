<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HWPX Text Reader</title>
    <!-- JSZip 라이브러리 (HWPX 내부 XML 압축 해제용 CDN) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { background: #101010; color: #fff; font-family: 'Segoe UI', sans-serif; padding: 40px; }
        .container { max-width: 800px; margin: 0 auto; display: flex; flex-direction: column; gap: 20px; }
        h1 { color: #ff9e40; font-size: 1.8rem; }
        .upload-box { border: 2px dashed #ff9e40; padding: 30px; text-align: center; border-radius: 12px; background: #181818; cursor: pointer; transition: 0.3s; }
        .upload-box:hover { background: #222; }
        input[type="file"] { display: none; }
        .output-box { background: #141414; border: 2px solid #ff9e40; border-radius: 12px; padding: 20px; min-height: 400px; max-height: 600px; overflow-y: auto; white-space: pre-wrap; font-family: 'Consolas', monospace; font-size: 0.9rem; line-height: 1.5; color: #ddd; }
        .placeholder { color: #666; text-align: center; margin-top: 150px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>HWPX Text Reader</h1>
        
        <label class="upload-box">
            <p style="color: #ff9e40; font-weight: bold; margin-bottom: 5px;">📁 HWPX 파일을 여기에 드래그하거나 클릭하여 업로드하세요</p>
            <p style="font-size: 0.8rem; color: #888;">(서버로 전송되지 않고 브라우저에서 안전하게 텍스트를 추출합니다)</p>
            <input type="file" id="hwpx-file" accept=".hwpx">
        </label>

        <div class="output-box" id="output">
            <div class="placeholder">파일이 업로드되면 여기에 내용이 표시됩니다.</div>
        </div>
    </div>

    <script>
        const fileInput = document.getElementById('hwpx-file');
        const outputBox = document.getElementById('output');

        fileInput.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;

            outputBox.innerHTML = '파일을 분석하는 중입니다...';

            try {
                // 1. HWPX는 ZIP 형식이므로 JSZip으로 읽기
                const zip = new JSZip();
                const zipContent = await zip.loadAsync(file);

                // 2. HWPX 본문은 보통 Contents/section*.xml 에 위치함
                let fullText = '';
                const sectionFiles = Object.keys(zipContent.files).filter(filename => 
                    filename.startsWith('Contents/section') && filename.endsWith('.xml')
                );

                if (sectionFiles.length === 0) {
                    outputBox.innerHTML = '유효한 HWPX 문서 구조를 찾을 수 없습니다. (HWP 구형 파일은 지원되지 않으며 HWPX만 지원합니다)';
                    return;
                }

                // 3. 각 섹션 XML 파일을 순회하며 텍스트(<hp:t> 등) 추출
                for (const filename of sectionFiles) {
                    const xmlText = await zipContent.files[filename].async('text');
                    const parser = new DOMParser();
                    const xmlDoc = parser.parseFromString(xmlText, 'text/xml');
                    
                    // HWPX 표준 태그 안의 텍스트 노드 추출
                    const textNodes = xmlDoc.getElementsByTagName('*');
                    for (let node of textNodes) {
                        // 텍스트를 담고 있는 태그 처리 (태그 이름에 t가 포함되거나 텍스트가 있는 경우)
                        if (node.children.length === 0 && node.textContent.trim() !== '') {
                            // XML 내부 메타데이터가 아닌 실제 본문 텍스트 라인화
                            fullText += node.textContent + '\n';
                        }
                    }
                    fullText += '\n--- [페이지 구분] ---\n\n';
                }

                outputBox.innerHTML = fullText ? fullText : '추출된 텍스트가 없습니다.';

            } catch (err) {
                console.error(err);
                outputBox.innerHTML = '파일을 읽는 중 오류가 발생했습니다: ' + err.message;
            }
        });
    </script>
</body>
</html>
