<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>Sequential SVG Animation</title>
    <style>
        body { display: flex; flex-direction: column; align-items: center; background: #000; color: white; padding-top: 50px; }
        #canvas-svg { border: 1px solid #333; margin-top: 20px; }
        .dot { transition: fill 0.4s ease; }
    </style>
</head>
<body>

    <input type="text" id="textInput" placeholder="단어를 입력하세요" maxlength="5">
    <button id="showBtn">보여주기</button>
    <svg id="canvas-svg" width="800" height="400" viewBox="0 0 800 400"></svg>

    <script>
        const svg = document.getElementById('canvas-svg');
        const input = document.getElementById('textInput');
        const btn = document.getElementById('showBtn');
        
        const rows = 20, cols = 40, size = 15;
        const circles = [];

        // 1. 격자 초기화
        for (let i = 0; i < rows; i++) {
            for (let j = 0; j < cols; j++) {
                const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
                circle.setAttribute("cx", 50 + j * size);
                circle.setAttribute("cy", 50 + i * size);
                circle.setAttribute("r", "3");
                circle.setAttribute("fill", "#21252a");
                circle.classList.add('dot');
                svg.appendChild(circle);
                circles.push(circle);
            }
        }

        // 2. 글자별 픽셀 데이터 추출 함수
        function getCharData(char) {
            const canvas = document.createElement('canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = cols; canvas.height = rows;
            ctx.fillStyle = 'white';
            ctx.font = 'bold 20px Arial';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(char, cols / 2, rows / 2);
            return ctx.getImageData(0, 0, cols, rows).data;
        }

        // 3. 버튼 클릭 이벤트 (순차 점등)
        btn.addEventListener('click', async () => {
            const text = input.value;
            // 모든 점 초기화
            circles.forEach(c => c.setAttribute("fill", "#21252a"));

            for (let char of text) {
                const imageData = getCharData(char);
                // 해당 글자 데이터 적용
                for (let i = 0; i < circles.length; i++) {
                    const alpha = imageData[i * 4 + 3];
                    if (alpha > 128) circles[i].setAttribute("fill", "#ffffff");
                }
                
                // 글자 간 대기 시간 (800ms)
                await new Promise(resolve => setTimeout(resolve, 800));
                
                // 다음 글자 위해 화면 초기화 (점등 유지하고 싶으면 이 줄을 삭제하세요)
                circles.forEach(c => c.setAttribute("fill", "#21252a"));
            }
        });
    </script>
</body>
</html>
